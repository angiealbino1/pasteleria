

<div class="form-card">
  <h1>Iniciar sesión</h1>

  <%= form_with url: login_path, method: :post do %>
    <%= email_field_tag :email, nil, placeholder: "Correo electrónico" %>

    <%= password_field_tag :password, nil, placeholder: "Contraseña" %>

    <%= submit_tag "Entrar", class: "btn" %>
  <% end %>

  <p>
    ¿No tienes cuenta?
    <%= link_to "Registrarse", registro_path %>
  </p>
</div>
