<!DOCTYPE html>
<html>
<head>
  <title>Dulce Delicia</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

<style>
*{box-sizing:border-box}
body{margin:0;font-family:Arial,sans-serif;background:#fff5f8;color:#333}
.navbar{background:linear-gradient(90deg,#ff4d6d,#ff8fa3);padding:18px 40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap}
.logo a{color:white;font-size:28px;font-weight:bold;text-decoration:none}
.menu{display:flex;gap:15px;align-items:center;flex-wrap:wrap}
.menu a,.menu span{color:white;text-decoration:none;font-weight:bold}
.main-container,.container{max-width:1200px;margin:auto;padding:40px 20px}
.titulo{text-align:center;font-size:40px;color:#ff4d6d;margin-bottom:30px}
.productos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:25px}
.producto-card{background:white;border-radius:20px;overflow:hidden;box-shadow:0 5px 18px rgba(0,0,0,.12);text-align:center}
.producto-img{width:100%;height:250px;object-fit:cover}
.producto-info{padding:20px}
.precio{color:#ff4d6d;font-size:24px;font-weight:bold}
.btn{background:#ff4d6d;color:white;padding:10px 18px;border-radius:10px;border:none;text-decoration:none;display:inline-block;margin:5px;font-weight:bold}
.btn-light{background:white;color:#ff4d6d}
.form-card,.form-box{max-width:450px;margin:50px auto;background:white;padding:35px;border-radius:20px;box-shadow:0 5px 18px rgba(0,0,0,.12);text-align:center}
input,textarea,select{width:100%;padding:12px;margin:8px 0 15px;border:1px solid #ddd;border-radius:10px}
footer,.footer{text-align:center;padding:25px;margin-top:40px;background:#ffe0ea}
@media(max-width:900px){.productos-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.productos-grid{grid-template-columns:1fr}.navbar{flex-direction:column;gap:15px}}
</style>

</head>

<body>

<header class="navbar">
  <div class="logo">
    <%= link_to "🍰 Dulce Delicia", root_path %>
  </div>

  <nav class="menu">
    <%= link_to "Inicio", root_path %>
    <%= link_to "Carrito", carritos_path %>
    <%= link_to "Mis pedidos", pedidos_path %>

    <% if sesion_iniciada? %>
      <% if admin? %>
        <%= link_to "Panel Admin", admin_pedidos_path %>
        <%= link_to "Nuevo producto", new_producto_path %>
      <% end %>

      <span>Hola, <%= usuario_actual.nombre %></span>

      <%= button_to "Cerrar sesión", logout_path, method: :delete, class: "btn btn-light" %>
    <% else %>
      <%= link_to "Iniciar sesión", login_path %>
      <%= link_to "Registrarse", registro_path %>
    <% end %>
  </nav>
</header>

<main class="main-container">
  <% if notice %>
    <div class="notice"><%= notice %></div>
  <% end %>

  <% if alert %>
    <div class="alert"><%= alert %></div>
  <% end %>

  <%= yield %>
</main>

<footer class="footer">
  <p>© 2026 Dulce Delicia - Postres hechos con amor 💖</p>
</footer>

</body>
</html>
