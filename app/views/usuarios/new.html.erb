
<div class="form-card">
  <h1>Crear cuenta</h1>

  <%= form_with model: @usuario, url: registro_path do |f| %>
    <%= f.text_field :nombre, placeholder: "Nombre completo" %>

    <%= f.email_field :email, placeholder: "Correo electrónico" %>

    <%= f.password_field :password, placeholder: "Contraseña" %>

    <%= f.password_field :password_confirmation, placeholder: "Confirmar contraseña" %>

    <%= f.submit "Registrarme", class: "btn" %>
  <% end %>
</div>

